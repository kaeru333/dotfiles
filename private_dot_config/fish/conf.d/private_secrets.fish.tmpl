# =============================================================================
# secrets.fish.tmpl — Bitwarden から機密情報を注入する fish 設定
# chezmoi apply 時に BW_SESSION が必要:
#   set -gx BW_SESSION (bw unlock --raw)
#   chezmoi apply
#
# トークンを回転する場合:
#   1. 各サービスで新しいトークンを発行
#   2. Bitwarden WebUI/CLI で該当アイテムを更新
#   3. chezmoi apply を再実行
# =============================================================================

{{- if .useBitwarden }}
# --- Slack (notify コマンド用) ---
set -Ux CLAUDE_WEBHOOK_URL     "{{ (bitwardenFields "item" "chezmoi/slack-secrets").webhook_url.value }}"
set -Ux SLACK_CLAUDE_BOT_TOKEN "{{ (bitwardenFields "item" "chezmoi/slack-secrets").bot_token.value }}"
set -Ux SLACK_CLAUDE_CHANNEL_ID "{{ (bitwardenFields "item" "chezmoi/slack-secrets").channel_id.value }}"

# --- Kaggle ---
set -Ux KAGGLE_API_TOKEN "{{ (bitwardenFields "item" "chezmoi/kaggle").api_token.value }}"
{{- else }}
# Bitwarden 未使用の場合は手動で値を設定してください
# set -Ux CLAUDE_WEBHOOK_URL     "..."
# set -Ux SLACK_CLAUDE_BOT_TOKEN "..."
# set -Ux SLACK_CLAUDE_CHANNEL_ID "..."
# set -Ux KAGGLE_API_TOKEN       "..."
{{- end }}
