#!/usr/bin/env bash
# SketchyBar config — AeroSpace workspaces (left) + system status (right).

CONFIG_DIR="$HOME/.config/sketchybar"
PLUGIN_DIR="$CONFIG_DIR/plugins"
export CONFIG_DIR PLUGIN_DIR
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH"

# ---- palette (Catppuccin Macchiato) ----
BAR_BG=0xff1e1e2e
SURFACE=0xff363a4f
TEXT=0xffcad3f5
DARK=0xff11111b
BLUE=0xff8aadf4
GREEN=0xffa6da95
YELLOW=0xffeed49f
RED=0xffed8796
MAUVE=0xffc6a0f6
PEACH=0xfff5a97f

ICON_FONT="0xProto Nerd Font Mono:Regular:15.0"
LABEL_FONT="SF Pro:Semibold:13.0"

# ---- icons (Nerd Font glyphs built from UTF-8 bytes; literals get stripped) ----
ICON_MEM=$(printf '\xef\x8b\x9b')   # nf-fa-microchip (U+F2DB) — RAM
ICON_CAL=$(printf '\xef\x81\xb3')   # nf-fa-calendar (U+F073)
ICON_CLK=$(printf '\xef\x80\x97')   # nf-fa-clock    (U+F017)
ICON_BAT=$(printf '\xef\x89\x80')   # nf-fa-battery-full (U+F240) placeholder
ICON_CAF=$(printf '\xef\x83\xb4')   # nf-fa-coffee (U+F0F4) — keep-awake toggle

# ---- bar (floating, bottom, frosted glass) ----
sketchybar --bar \
  height=32 \
  position=bottom \
  sticky=on \
  margin=12 \
  y_offset=4 \
  corner_radius=14 \
  border_width=2 \
  border_color=0x33ffffff \
  blur_radius=30 \
  color=0xcc1e1e2e \
  padding_left=12 \
  padding_right=12

# ---- defaults ----
sketchybar --default \
  label.font="SF Pro:Semibold:14.0" \
  icon.font="SF Pro:Semibold:14.0" \
  label.color=$TEXT \
  icon.color=$TEXT \
  padding_left=3 \
  padding_right=3

# ---- AeroSpace workspaces (left) ----
sketchybar --add event aerospace_workspace_change

for sid in $(aerospace list-workspaces --all); do
  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      label="$sid" \
      label.padding_left=9 \
      label.padding_right=9 \
      background.color=$BLUE \
      background.corner_radius=11 \
      background.height=24 \
      background.drawing=off \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/aerospace.sh $sid"
done

# ---- system status (right) ----
# Added right-to-left: clock is rightmost, memory is leftmost.
# Resulting order L->R:  memory  battery  clock

sketchybar --add item clock right \
  --set clock \
    icon="$ICON_CLK" icon.color=$BLUE icon.font="$ICON_FONT" \
    icon.padding_left=10 icon.padding_right=5 \
    label.font="$LABEL_FONT" label.color=$TEXT label.padding_right=10 \
    update_freq=15 script="$PLUGIN_DIR/clock.sh" \
  --subscribe clock system_woke

sketchybar --add item battery right \
  --set battery \
    icon="$ICON_BAT" icon.color=$GREEN icon.font="$ICON_FONT" \
    icon.padding_left=10 icon.padding_right=5 \
    label.font="$LABEL_FONT" label.color=$TEXT label.padding_right=10 \
    update_freq=120 script="$PLUGIN_DIR/battery.sh" \
  --subscribe battery power_source_change system_woke

sketchybar --add item memory right \
  --set memory \
    icon="$ICON_MEM" icon.color=$MAUVE icon.font="$ICON_FONT" \
    icon.padding_left=10 icon.padding_right=5 \
    label.font="$LABEL_FONT" label.color=$TEXT label.padding_right=10 \
    update_freq=10 script="$PLUGIN_DIR/memory.sh" \
  --subscribe memory system_woke

# ---- caffeine toggle (standalone button, left of the status group) ----
# Click cycles: off -> system only -> screen+system -> all -> off
sketchybar --add item caffeine right \
  --set caffeine \
    icon="$ICON_CAF" icon.color=0xff6e738d icon.font="$ICON_FONT" \
    icon.padding_left=10 icon.padding_right=5 \
    label.font="$LABEL_FONT" label.color=$PEACH label.padding_right=10 \
    label.drawing=off \
    update_freq=30 script="$PLUGIN_DIR/caffeine.sh" \
    click_script="$PLUGIN_DIR/caffeine.sh toggle" \
  --subscribe caffeine system_woke

# Wrap the status items in one rounded container.
sketchybar --add bracket status memory battery clock \
  --set status \
    background.color=$SURFACE \
    background.corner_radius=11 \
    background.height=26

# ---- finalize & set initial workspace highlight ----
sketchybar --update
sketchybar --trigger aerospace_workspace_change \
  FOCUSED_WORKSPACE="$(aerospace list-workspaces --focused)"
